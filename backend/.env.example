# ProspectPilot AI — Environment Variables
# Copy to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://prospectpilot:prospectpilot_dev@localhost:5432/prospectpilot

# Redis
REDIS_URL=redis://localhost:6379/0

# AI Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# SendGrid Email
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=hello@prospectpilot.ai

# App
SECRET_KEY=change-me-in-production
DEBUG=true